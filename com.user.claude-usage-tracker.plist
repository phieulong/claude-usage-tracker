<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.phieulong.claude-usage-tracker</string>

    <key>ProgramArguments</key>
    <array>
        <!-- Homebrew Apple Silicon: /opt/homebrew/bin/claude-usage-tracker -->
        <!-- Homebrew Intel:         /usr/local/bin/claude-usage-tracker      -->
        <!-- .app bundle:  /Applications/Claude Usage Tracker.app/Contents/MacOS/claude-usage-tracker -->
        <string>/opt/homebrew/bin/claude-usage-tracker</string>
        <string>daemon</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/claude-usage-tracker.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/claude-usage-tracker.err</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>RUST_LOG</key>
        <string>info</string>
    </dict>
</dict>
</plist>
